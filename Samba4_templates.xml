            <discovery_rules>
                <discovery_rule>
                    <uuid>1491b8ccf5524c469fb35d38ee442eca</uuid>
                    <name>SAMBA4 AD NTDS connections</name>
                    <type>DEPENDENT</type>
                    <key>samba.ntds.connections</key>
                    <lifetime>1h</lifetime>
                    <enabled_lifetime_type>DISABLE_NEVER</enabled_lifetime_type>
                    <item_prototypes>
                        <item_prototype>
                            <uuid>775f80c088364a0abc4267cdf3010901</uuid>
                            <name>SAMBA4 AD NTDS connection to {#DNS_NAME}</name>
                            <type>DEPENDENT</type>
                            <key>samba.ntds.connections[{#DNS_NAME}]</key>
                            <history>7d</history>
                            <value_type>TEXT</value_type>
                            <preprocessing>
                                <step>
                                    <type>JSONPATH</type>
                                    <parameters>
                                        <parameter>$.NTDSConnections[?(@[&quot;dns name&quot;] == &quot;{#DNS_NAME}&quot;)].first()</parameter>
                                    </parameters>
                                </step>
                            </preprocessing>
                            <master_item>
                                <key>samba4cmd[replicas]</key>
                            </master_item>
                        </item_prototype>
                    </item_prototypes>
                    <master_item>
                        <key>samba4cmd[replicas]</key>
                    </master_item>
                    <lld_macro_paths>
                        <lld_macro_path>
                            <lld_macro>{#DNS_NAME}</lld_macro>
                            <path>$[&quot;dns name&quot;]</path>
                        </lld_macro_path>
                    </lld_macro_paths>
                    <preprocessing>
                        <step>
                            <type>JSONPATH</type>
                            <parameters>
                                <parameter>$.NTDSConnections[*]</parameter>
                            </parameters>
                        </step>
                    </preprocessing>
                </discovery_rule>
                <discovery_rule>
                    <uuid>fb269d2ac0db40b58f737339f9dd9a15</uuid>
                    <name>SAMBA4 AD NTDS replications from</name>
                    <type>DEPENDENT</type>
                    <key>samba.ntds.replications_from</key>
                    <lifetime>1h</lifetime>
                    <enabled_lifetime_type>DISABLE_NEVER</enabled_lifetime_type>
                    <item_prototypes>
                        <item_prototype>
                            <uuid>52fe352f2be741739ea6fc9bfcb42d73</uuid>
                            <name>SAMBA4 AD NTDS replication from {#DSA} of {#NC_DN}</name>
                            <type>DEPENDENT</type>
                            <key>samba.ntds.replications_from[{#DSA},{#NC_DN}]</key>
                            <preprocessing>
                                <step>
                                    <type>JSONPATH</type>
                                    <parameters>
                                        <parameter>$.repsFrom[?(@[&quot;NC dn&quot;] == &quot;{#NC_DN}&quot;)][&quot;consecutive failures&quot;].first()</parameter>
                                    </parameters>
                                </step>
                            </preprocessing>
                            <master_item>
                                <key>samba4cmd[replicas]</key>
                            </master_item>
                            <trigger_prototypes>
                                <trigger_prototype>
                                    <uuid>99fecdbb7ec545268e404cbdb5bb1bea</uuid>
                                    <expression>last(/Samba4 AD/samba.ntds.replications_from[{#DSA},{#NC_DN}])&gt;0</expression>
                                    <name>Check Samba 4 AD Replication From {#DSA} {#NC_DN}</name>
                                    <priority>WARNING</priority>
                                    <manual_close>YES</manual_close>
                                </trigger_prototype>
                            </trigger_prototypes>
                        </item_prototype>
                    </item_prototypes>
                    <master_item>
                        <key>samba4cmd[replicas]</key>
                    </master_item>
                    <lld_macro_paths>
                        <lld_macro_path>
                            <lld_macro>{#DSA_OBJECTGUID}</lld_macro>
                            <path>$[&quot;DSA objectGUID&quot;]</path>
                        </lld_macro_path>
                        <lld_macro_path>
                            <lld_macro>{#DSA}</lld_macro>
                            <path>$[&quot;DSA&quot;]</path>
                        </lld_macro_path>
                        <lld_macro_path>
                            <lld_macro>{#NC_DN}</lld_macro>
                            <path>$[&quot;NC dn&quot;]</path>
                        </lld_macro_path>
                    </lld_macro_paths>
                    <preprocessing>
                        <step>
                            <type>JSONPATH</type>
                            <parameters>
                                <parameter>$.repsFrom[?(@[&quot;consecutive failures&quot;] &gt;-1)]</parameter>
                            </parameters>
                        </step>
                    </preprocessing>
                </discovery_rule>
